    "n = int(input('enter the number'))\n",
    "if n>1 :\n",
    "        for i in range(2,n) :\n",
    "            if (n%i==0):\n",
    "                print('Not a PRIME Number')\n",
    "                break\n",
    "        else :\n",
    "                print (' prime number')\n",
    "\n",
    "else :\n",
    "        print('not a prime number')"
